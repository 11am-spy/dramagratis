{
  "builds": [
    {
      "src": "api/dramas.js",
      "use": "@vercel/node"
    },
    {
      "src": "index.html",
      "use": "@vercel/static"
    },
    {
      "src": "style.css",
      "use": "@vercel/static"
    },
    {
      "src": "script.js",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/dramas",
      "dest": "api/dramas.js"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ]
}
